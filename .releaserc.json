{
	"branches": ["main"],
	"plugins": [
		[
			"@semantic-release/commit-analyzer",
			{
				"preset": "angular",
				"releaseRules": [
					{
						"message": "*/fix/*",
						"release": "patch"
					},
					{
						"message": "*/hotfix/*",
						"release": "patch"
					},
					{
						"message": "*/feat/*",
						"release": "minor"
					},
					{
						"message": "*/release/*",
						"release": "major"
					},
					{
						"type": "fix",
						"release": "patch"
					},
					{
						"type": "feat",
						"release": "minor"
					}
				]
			}
		],
		"@semantic-release/release-notes-generator",
		[
			"@semantic-release/npm",
			{
				"pkgRoot": "."
			}
		],
		[
			"@semantic-release/git",
			{
				"assets": ["package.json"],
				"message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
			}
		],
		"@semantic-release/github"
	]
}
